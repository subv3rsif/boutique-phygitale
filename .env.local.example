# ============================================================================
# FICHIER DE CONFIGURATION ENVIRONNEMENT LOCAL
# ============================================================================
# Copier ce fichier vers .env.local et remplir avec vos vraies valeurs
# Voir docs/ENVIRONMENT_SETUP.md pour les instructions détaillées

# ============================================================================
# BASE DE DONNÉES (Supabase PostgreSQL)
# ============================================================================
# Récupérer depuis : Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ============================================================================
# SUPABASE API & STORAGE
# ============================================================================
# Récupérer depuis : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ============================================================================
# EMAILS (RESEND)
# ============================================================================
# Récupérer depuis : https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@votre-domaine.fr

# ============================================================================
# UPSTASH REDIS (Rate Limiting)
# ============================================================================
# Récupérer depuis : https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://xxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AYCxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# APPLICATION
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================================
# AUTHENTIFICATION ADMIN
# ============================================================================
# Emails autorisés (séparés par virgules)
ADMIN_EMAILS=votre-email@example.com
ADMIN_PASSWORD=dev123

# ============================================================================
# NEXTAUTH (Google OAuth)
# ============================================================================
# Générer NEXTAUTH_SECRET avec : openssl rand -base64 32
# Google OAuth : https://console.cloud.google.com/apis/credentials
NEXTAUTH_SECRET=VotreSecretGenereAvecOpenSSL
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# LIEU DE RETRAIT
# ============================================================================
NEXT_PUBLIC_PICKUP_LOCATION_NAME=La Fabrik
NEXT_PUBLIC_PICKUP_LOCATION_ADDRESS=36 Rue Véron, 94140 Alfortville
NEXT_PUBLIC_PICKUP_LOCATION_HOURS=Lundi-Vendredi 14h-18h, Samedi 10h-12h

# ============================================================================
# CRON (Tâches planifiées)
# ============================================================================
# Générer avec : openssl rand -hex 32
CRON_SECRET=votre_secret_cron_aleatoire

# ============================================================================
# SENTRY (Monitoring d'erreurs - OPTIONNEL)
# ============================================================================
# Exemple avec les vraies variables Sentry :

# DSN public (frontend error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://03e2d2947abf44ec0ff7d08d478838cd@o4511178706976768.ingest.de.sentry.io/4511178708877392

# Auth token (pour upload source maps)
SENTRY_AUTH_TOKEN=b639efe9f99f8ea588fdb683d56944a832eda1b2a143632ffd1aeea8986ec958

# Organisation et projet
SENTRY_ORG=alf-boutique
SENTRY_PROJECT=sentry-sky-leaf

# Clé publique (extraite du DSN)
SENTRY_PUBLIC_KEY=03e2d2947abf44ec0ff7d08d478838cd

# OTLP Traces URL (OpenTelemetry)
SENTRY_OTLP_TRACES_URL=https://o4511178706976768.ingest.de.sentry.io/api/4511178708877392/integration/otlp/v1/traces

# Vercel Log Drain
SENTRY_VERCEL_LOG_DRAIN_URL=https://o4511178706976768.ingest.de.sentry.io/api/4511178708877392/integration/vercel/logs/

# ============================================================================
# PAYFIP (Paiement Tipi Régie)
# ============================================================================
# Mode Mock pour développement (pas besoin de vrais credentials)
PAYFIP_USE_MOCK=true
PAYFIP_NUMCLI=999999999999999
PAYFIP_EXER=2026
PAYFIP_URL=https://www.tipi.budget.gouv.fr/tpa/services/securite
PAYFIP_MODE=T
